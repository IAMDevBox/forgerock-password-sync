{
  "_comment": "Scheduled task to retry failed password syncs every 15 minutes.",
  "_tutorial": "https://www.iamdevbox.com/posts/complete-workflow-for-password-synchronization-from-forgerock-idm-to-identity-cloud/",
  "enabled": true,
  "type": "cron",
  "schedule": "0 0/15 * * * ?",
  "_comment_schedule": "Cron: every 15 minutes. Adjust as needed (every 30 min: '0 0/30 * * * ?')",
  "persisted": true,
  "misfirePolicy": "doNothing",
  "invokeService": "script",
  "invokeContext": {
    "script": {
      "type": "groovy",
      "file": "script/retry-failed-password-syncs.groovy"
    }
  },
  "startTime": null,
  "endTime": null,
  "timeZone": "UTC"
}
